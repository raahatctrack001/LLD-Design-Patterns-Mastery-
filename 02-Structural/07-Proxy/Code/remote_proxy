#include <iostream>
#include <memory>
#include <thread>
#include <chrono>

using namespace std;

class IWeatherService {

public:

    virtual string getWeather(
        const string& city
    ) = 0;

    virtual ~IWeatherService() {}
};



class RealWeatherServer
    : public IWeatherService {

public:

    string getWeather(
        const string& city
    ) override {

        cout
            << "[REMOTE SERVER]"
            << endl;

        cout
            << "Fetching live weather data..."
            << endl;

        this_thread::sleep_for(
            chrono::seconds(2)
        );

        return
            "Weather in " +
            city +
            " : 32 C Sunny";
    }
};



class WeatherServiceProxy
    : public IWeatherService {

private:

    string serverAddress;

public:

    WeatherServiceProxy(
        const string& address
    )
        : serverAddress(address)
    {}

    string getWeather(
        const string& city
    ) override {

        cout
            << "[PROXY] Authenticating request..."
            << endl;

        this_thread::sleep_for(
            chrono::milliseconds(500)
        );

        cout
            << "[PROXY] Connecting to remote server: "
            << serverAddress
            << endl;

        cout
            << "[PROXY] Serializing request..."
            << endl;

        this_thread::sleep_for(
            chrono::milliseconds(500)
        );

        cout
            << "[PROXY] Sending request over network..."
            << endl;

        this_thread::sleep_for(
            chrono::seconds(1)
        );

        bool serverReachable = true;

        if(!serverReachable) {

            return
                "[PROXY ERROR] Remote server unavailable";
        }

        RealWeatherServer remoteServer;

        string response =
            remoteServer.getWeather(city);

        cout
            << "[PROXY] Receiving response..."
            << endl;

        this_thread::sleep_for(
            chrono::milliseconds(500)
        );

        cout
            << "[PROXY] Deserializing response..."
            << endl;

        return response;
    }
};



int main() {

    unique_ptr<IWeatherService>
        weatherService =
            make_unique<WeatherServiceProxy>(
                "https://weather-api-server.com"
            );

    cout
        << "Client requesting weather data..."
        << endl;

    cout << endl;

    string result =
        weatherService->getWeather(
            "Delhi"
        );

    cout << endl;

    cout
        << "[CLIENT RECEIVED]"
        << endl;

    cout
        << result
        << endl;

    return 0;
}